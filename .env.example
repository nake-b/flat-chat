POSTGRES_USER=flat_chat
POSTGRES_PASSWORD=flat_chat
POSTGRES_DB=flat_chat
DATABASE_URL=postgresql://flat_chat:flat_chat@postgres:5432/flat_chat

# LLM Configuration
LLM_MODEL=openrouter/openrouter/free
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Retry config: high for dev (free tier rate limits), low for prod (fast failure)
LLM_NUM_RETRIES=5
LLM_RETRY_AFTER=5
