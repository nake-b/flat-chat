POSTGRES_USER=flat_chat
POSTGRES_PASSWORD=flat_chat
POSTGRES_DB=flat_chat
DATABASE_URL=postgresql://flat_chat:flat_chat@postgres:5432/flat_chat

# --- Host-only (you, if you're the one hosting the shared tailnet DB) -------
# Uncomment to load the tailscale sidecar overlay on top of the base stack.
# Teammates leave these unset — their `docker compose up` brings up just the
# local stack without any tailnet device, and they refresh data with
# ./scripts/refresh-db.sh.
# COMPOSE_FILE=docker-compose.yml:docker-compose.host.yml
# TS_AUTHKEY=tskey-auth-<your-key>   # https://login.tailscale.com/admin/settings/keys (tag:flat-chat-db, reusable, non-ephemeral)

# --- LLM — Anthropic-direct (preferred when set; enables prompt caching) ----
# ANTHROPIC_MODEL defaults to claude-sonnet-4-6.
ANTHROPIC_API_KEY=<your-key>
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- LLM — Azure OpenAI (classic Azure OpenAI Service) ----------------------
# DEPLOYMENT is the name you typed when creating the deployment in Foundry.
# API_VERSION must be a preview version for o-series reasoning models.
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=o4-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Jina Embeddings (optional — leave empty to disable semantic search) ----
JINA_API_KEY=<your-key>
JINA_BASE_URL=https://api.jina.ai/v1

# --- Geocoding fallback (silver step; fills missing listing coordinates) -----
# Open address→coordinate API used to backfill listings that arrive without a
# scraped point (e.g. wohninberlin). Defaults to the public Nominatim instance
# (no key; ≤1 req/s; requires an identifying User-Agent). Point the base URL at
# a self-hosted Nominatim / Photon for bulk backfills.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=flat-chat-geocoder/1.0 (+https://github.com/nake-b/flat-chat)
GEOCODER_RATE_LIMIT_S=1.0

# --- Observability (dev only; Phoenix UI at http://localhost:6006) ----------
PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006/v1/traces

# --- Logging ----------------------------------------------------------------
# Backend log level for the `flat_chat` namespace. Third-party loggers
# stay at WARNING regardless. DEBUG / INFO / WARNING / ERROR / CRITICAL.
LOG_LEVEL=INFO

# --- Auth (fastapi-users) ---------------------------------------------------
# JWT_SECRET signs the login cookie and is REQUIRED (no insecure default ships).
# Left blank on purpose: the backend fails loudly on startup if it's unset, so a
# forgotten secret can't slip through as a placeholder. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotating it logs everyone out. JWT_LIFETIME_SECONDS defaults to 7 days.
JWT_SECRET=
JWT_LIFETIME_SECONDS=604800
# Cookie Secure attribute: false for local HTTP, true for any HTTPS deployment.
COOKIE_SECURE=false
# Accounts (created by `scripts/seed_users.py` — there is NO public
# signup). dev is an admin; the prof pair is optional (a reviewer login) and only
# seeded when both are set. Override in any deployment.
DEV_USER_EMAIL=dev@flatchat.dev
DEV_USER_PASSWORD=dev
PROF_USER_EMAIL=
PROF_USER_PASSWORD=
