POSTGRES_USER=flat_chat
POSTGRES_PASSWORD=flat_chat
POSTGRES_DB=flat_chat
DATABASE_URL=postgresql://flat_chat:flat_chat@postgres:5432/flat_chat

# LLM Configuration (Pydantic AI + OpenRouter)
# OPENROUTER_MODEL accepts either a model slug ("anthropic/claude-3.5-sonnet")
# or a preset ("@preset/<slug>") — create presets at
# https://openrouter.ai/settings/presets to control fallback chains server-side.
OPENROUTER_API_KEY=<your-key>
OPENROUTER_MODEL=@preset/your-preset

# Anthropic-direct (optional). When set, takes precedence over OpenRouter so
# native prompt caching kicks in; OpenRouter (if also set) becomes a fallback
# on ModelAPIError. ANTHROPIC_MODEL defaults to claude-sonnet-4-6.
ANTHROPIC_API_KEY=<your-key>
ANTHROPIC_MODEL=claude-sonnet-4-6

# Jina Embeddings (optional — leave empty to disable semantic search)
JINA_API_KEY=<your-key>
JINA_BASE_URL=https://api.jina.ai/v1

# Observability (dev only; Phoenix UI at http://localhost:6006)
PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006/v1/traces
