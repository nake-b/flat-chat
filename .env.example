POSTGRES_USER=flat_chat
POSTGRES_PASSWORD=flat_chat
POSTGRES_DB=flat_chat
DATABASE_URL=postgresql://flat_chat:flat_chat@postgres:5432/flat_chat

# LLM Configuration (Pydantic AI + Anthropic-direct, native prompt caching)
# ANTHROPIC_MODEL defaults to claude-sonnet-4-6.
ANTHROPIC_API_KEY=<your-key>
ANTHROPIC_MODEL=claude-sonnet-4-6

# Jina Embeddings (optional — leave empty to disable semantic search)
JINA_API_KEY=<your-key>
JINA_BASE_URL=https://api.jina.ai/v1

# Observability (dev only; Phoenix UI at http://localhost:6006)
PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006/v1/traces
